NODE_ENV=development
PORT=3001

# JWT — generează cu: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_ai

# Resend (email)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@yourdomain.com

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_MONTHLY_ID=price_...
STRIPE_PRICE_ANNUAL_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Groq AI
GROQ_API_KEY=gsk_...

# Admin (opțional)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SECRET=change_me_admin_secret_min_32_chars

# Criptare la rest credențiale WhatsApp (H2) — generează cu: openssl rand -hex 32
# Fără ea, sesiunile WhatsApp se stochează NECRIPTAT (avertisment la pornire).
WHATSAPP_ENC_KEY=change_me_whatsapp_enc_key_min_32_chars
