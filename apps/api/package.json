{
  "name": "api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "prebuild": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "build": "tsc",
    "start": "node dist/db/migrate.js && node dist/index.js",
    "db:migrate": "tsx src/db/migrate.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^9.4.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^10.1.1",
    "@fastify/multipart": "^8.3.1",
    "@fastify/rate-limit": "^9.1.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "6.17.16",
    "bcryptjs": "^2.4.3",
    "disposable-email-domains": "^1.0.62",
    "dotenv": "^16.4.5",
    "drizzle-orm": "^0.30.10",
    "fastify": "^4.27.0",
    "mammoth": "^1.12.0",
    "node-cache": "^5.1.2",
    "pdf-parse": "^2.4.5",
    "pg": "^8.21.0",
    "resend": "^3.2.0",
    "stripe": "^22.1.1",
    "uuid": "^9.0.1",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/node": "^20.14.0",
    "@types/node-cache": "^4.2.5",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.20.0",
    "@types/uuid": "^9.0.8",
    "@vitest/coverage-v8": "^4.1.7",
    "form-data": "^4.0.5",
    "tsx": "^4.11.0",
    "typescript": "^5.4.5",
    "vitest": "^4.1.7"
  }
}
