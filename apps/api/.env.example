NODE_ENV=development
PORT=3001

# JWT — generează cu: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=change_me_access_secret_min_32_chars
JWT_REFRESH_SECRET=change_me_refresh_secret_min_32_chars
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# PostgreSQL
DATABASE_URL=postgresql://user:password@localhost:5432/whatsapp_ai

# Resend (email)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=noreply@yourdomain.com

# URLs
APP_URL=http://localhost:3000
API_URL=http://localhost:3001

# Stripe
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PRICE_PRO_MONTHLY=price_...  # tier Pro 79
STRIPE_PRICE_PRO_ANNUAL=price_...   # tier Pro 790
STRIPE_PRICE_MAX_MONTHLY=price_...  # tier Max 129
STRIPE_PRICE_MAX_ANNUAL=price_...   # tier Max 1290
STRIPE_WEBHOOK_SECRET=whsec_...

# Groq AI
GROQ_API_KEY=gsk_...

# Admin (opțional)
ADMIN_EMAIL=admin@yourdomain.com
ADMIN_SECRET=change_me_admin_secret_min_32_chars
# Secret dedicat pentru sesiunea admin (M5) — izolat de JWT. openssl rand -hex 32
# Fără el, sesiunea admin se derivă din JWT_ACCESS_SECRET (avertisment la pornire).
ADMIN_SESSION_SECRET=change_me_admin_session_secret_min_32
# 2FA (TOTP) la login-ul admin — OPȚIONAL. Generează cu: tsx src/scripts/gen-admin-totp.ts
# Dacă e setat, POST /admin/auth cere și un cod de 6 cifre dintr-o aplicație authenticator.
# Dacă lipsește, 2FA e sărit (back-compat). Setează-l în Railway pentru producție.
# ADMIN_TOTP_SECRET=base32_secret_generat_cu_scriptul

# Criptare la rest credențiale WhatsApp (H2) — generează cu: openssl rand -hex 32
# Fără ea, sesiunile WhatsApp se stochează NECRIPTAT (avertisment la pornire).
WHATSAPP_ENC_KEY=change_me_whatsapp_enc_key_min_32_chars

# Nr. proxy-uri de încredere pentru rate-limit/IP real (M1). NU pune `true`. Railway direct=1,
# prin Cloudflare=2 (doar dacă blochezi accesul direct la *.up.railway.app). Default: 1.
TRUST_PROXY_HOPS=1
